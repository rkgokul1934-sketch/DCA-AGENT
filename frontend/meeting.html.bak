<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DCA | Strategic Boardroom</title>
    <link rel="stylesheet" href="styles.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --bg-dark: #020617;
            --panel-bg: rgba(15, 23, 42, 0.45);
            --glass-border: rgba(255, 255, 255, 0.08);
            --accent-blue: #6366f1;
            --accent-glow: rgba(99, 102, 241, 0.3);
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --success: #10b981;
        }

        body {
            background: var(--bg-dark);
            font-family: 'Outfit', 'Inter', sans-serif;
            color: var(--text-primary);
            height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .boardroom-container {
            width: 100%;
            max-width: 1200px;
            height: calc(100vh - 100px);
            padding: 2rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .header-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--panel-bg);
            backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            padding: 1rem 2rem;
            border-radius: 20px;
        }

        .header-title {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .header-title h2 {
            font-size: 1.1rem;
            letter-spacing: 1px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .meeting-status-badge {
            font-size: 0.65rem;
            font-weight: 800;
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border: 1px solid var(--success);
            padding: 4px 10px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .pulse-light {
            width: 6px;
            height: 6px;
            background: var(--success);
            border-radius: 50%;
            animation: pulse-dot 1.5s infinite;
        }

        @keyframes pulse-dot {
            0% { transform: scale(0.95); opacity: 0.5; }
            50% { transform: scale(1.2); opacity: 1; }
            100% { transform: scale(0.95); opacity: 0.5; }
        }

        .workspace-grid {
            flex: 1;
            display: grid;
            grid-template-columns: 1.6fr 1fr;
            gap: 1.5rem;
            min-height: 0;
        }

        .video-hub {
            background: var(--panel-bg);
            backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            border-radius: 28px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
        }

        .lobby-screen {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            text-align: center;
        }

        .lobby-avatar {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            box-shadow: 0 0 30px var(--accent-glow);
        }

        .join-trigger {
            background: linear-gradient(90deg, #6366f1, #a855f7);
            border: none;
            color: white;
            font-size: 1.1rem;
            font-weight: 800;
            padding: 1.2rem 3rem;
            border-radius: 100px;
            cursor: pointer;
            box-shadow: 0 10px 30px var(--accent-glow);
            transition: 0.3s;
            margin-top: 2rem;
            letter-spacing: 0.5px;
        }

        .join-trigger:hover {
            transform: scale(1.05);
            box-shadow: 0 15px 40px var(--accent-glow);
        }

        .active-meeting-screen {
            display: none;
            flex: 1;
            flex-direction: column;
            padding: 1.5rem;
            gap: 1.5rem;
        }

        .video-grid {
            flex: 1;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            min-height: 0;
        }

        .video-feed {
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .video-feed img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.85;
        }

        .feed-label {
            position: absolute;
            bottom: 15px;
            left: 15px;
            background: rgba(0,0,0,0.6);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .meeting-controls {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            background: rgba(0,0,0,0.3);
            padding: 1rem;
            border-radius: 20px;
            border: 1px solid var(--glass-border);
        }

        .control-btn {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: white;
            width: 46px;
            height: 46px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.3s;
        }

        .control-btn:hover {
            background: rgba(255,255,255,0.15);
            transform: translateY(-2px);
        }

        .control-btn.danger {
            background: rgba(239, 68, 68, 0.2);
            border-color: #ef4444;
            color: #ef4444;
        }

        .copilot-panel {
            background: var(--panel-bg);
            backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            border-radius: 28px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .copilot-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--glass-border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .copilot-header h3 {
            font-size: 0.85rem;
            font-weight: 800;
            letter-spacing: 1px;
            color: var(--text-secondary);
            text-transform: uppercase;
        }

        .copilot-body {
            flex: 1;
            padding: 1.5rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            min-height: 0;
        }

        .transcription-bubble {
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--glass-border);
            padding: 1rem;
            border-radius: 16px;
            border-bottom-left-radius: 4px;
            font-size: 0.8rem;
            line-height: 1.5;
            opacity: 0;
            transform: translateY(10px);
            animation: bubble-in 0.5s forwards;
        }

        .transcription-bubble.ai-intel {
            background: rgba(99, 102, 241, 0.05);
            border-color: rgba(99, 102, 241, 0.2);
            border-bottom-left-radius: 16px;
            border-bottom-right-radius: 4px;
        }

        .speaker-label {
            font-size: 0.6rem;
            font-weight: 800;
            color: var(--accent-blue);
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        @keyframes bubble-in {
            to { opacity: 1; transform: translateY(0); }
        }

        .progress-container {
            padding: 1rem 1.5rem;
            border-top: 1px solid var(--glass-border);
            background: rgba(0,0,0,0.1);
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            font-size: 0.6rem;
            font-weight: 800;
            color: var(--text-secondary);
            margin-bottom: 6px;
            letter-spacing: 0.5px;
        }

        .bar-outer {
            height: 6px;
            background: rgba(255,255,255,0.05);
            border-radius: 10px;
            overflow: hidden;
        }

        .bar-inner {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #6366f1, #a855f7);
            border-radius: 10px;
            transition: width 1s linear;
        }

        /* Post-Meeting Intelligence Report overlay */
        .report-overlay {
            position: absolute;
            inset: 0;
            background: #020617;
            z-index: 10;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            overflow-y: auto;
        }

        .report-card {
            width: 100%;
            max-width: 650px;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(99, 102, 241, 0.3);
            border-radius: 32px;
            padding: 2.5rem;
            box-shadow: 0 0 40px rgba(99, 102, 241, 0.15);
            text-align: center;
        }

        .report-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 2rem;
        }

        .report-title h1 {
            font-size: 1.5rem;
            font-weight: 800;
            background: linear-gradient(to right, #fff, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .dossier-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .dossier-item {
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--glass-border);
            padding: 1.2rem;
            border-radius: 18px;
            text-align: left;
        }

        .dossier-lbl {
            font-size: 0.6rem;
            color: var(--text-secondary);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .dossier-val {
            font-size: 1rem;
            font-weight: 700;
            color: white;
        }

        .next-action-card {
            background: linear-gradient(90deg, rgba(99, 102, 241, 0.15), transparent);
            border-left: 4px solid var(--accent-blue);
            padding: 1.5rem;
            border-radius: 16px;
            text-align: left;
            margin-bottom: 2.5rem;
            position: relative;
        }

        .next-action-card::after {
            content: 'NEXT BEST ACTION';
            position: absolute;
            top: 10px;
            right: 15px;
            font-size: 0.55rem;
            font-weight: 800;
            color: var(--accent-blue);
            letter-spacing: 0.5px;
        }

        .back-dashboard-btn {
            background: var(--text-primary);
            color: var(--bg-dark);
            font-size: 0.95rem;
            font-weight: 800;
            padding: 1rem 3rem;
            border-radius: 100px;
            border: none;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(255,255,255,0.1);
        }

        .back-dashboard-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255,255,255,0.25);
        }
    </style>
</head>
<body>
    <div class="boardroom-container">
        <!-- Top Title & Badge -->
        <header class="header-bar">
            <div class="header-title">
                <i data-lucide="video" style="color: var(--accent-blue)"></i>
                <h2 id="m-title">Strategic Boardroom</h2>
            </div>
            <div class="meeting-status-badge">
                <div class="pulse-light"></div>
                <span id="lobby-status">LOBBY IS READY</span>
            </div>
        </header>

        <!-- Main Grid -->
        <div class="workspace-grid">
            <!-- Left Side: Interactive Video / Simulation Screen -->
            <div class="video-hub">
                <!-- Lobby State -->
                <div class="lobby-screen" id="lobby-state">
                    <div class="lobby-avatar">GTM</div>
                    <h1 style="font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem;">Strategic Alignment Session</h1>
                    <p style="color: var(--text-secondary); max-width: 500px; line-height: 1.6; font-size: 0.95rem;">
                        Secure enterprise-grade video channel configured. Your GTM Strategic Host is waiting in the boardroom.
                    </p>
                    <button class="join-trigger" id="join-btn">JOIN SECURE SESSION NOW</button>
                </div>

                <!-- Active Meeting State -->
                <div class="active-meeting-screen" id="meeting-state">
                    <div class="video-grid">
                        <div class="video-feed">
                            <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=600" alt="Sarah - RevOps Host">
                            <div class="feed-label">Host: Sarah Jenkins (DCA RevOps)</div>
                        </div>
                        <div class="video-feed">
                            <div style="text-align: center; color: var(--text-secondary);">
                                <div style="width: 70px; height: 70px; background: rgba(255,255,255,0.05); border: 2px solid var(--accent-blue); border-radius: 50%; margin: 0 auto 1rem; display: flex; align-items: center; justify-content: center; color: var(--accent-blue);">
                                    <i data-lucide="user" size="32"></i>
                                </div>
                                <span id="client-feed-name" style="font-weight: 700; color: white;">Prospect (You)</span>
                            </div>
                            <div class="feed-label" id="client-feed-label">Prospect Client</div>
                        </div>
                    </div>

                    <!-- Room Control Buttons -->
                    <div class="meeting-controls">
                        <button class="control-btn" title="Mute"><i data-lucide="mic"></i></button>
                        <button class="control-btn" title="Stop Video"><i data-lucide="video"></i></button>
                        <button class="control-btn" title="Share Screen"><i data-lucide="monitor"></i></button>
                        <button class="control-btn" title="Settings"><i data-lucide="settings"></i></button>
                        <button class="control-btn danger" id="leave-btn" title="End Session"><i data-lucide="phone-off"></i></button>
                    </div>
                </div>

                <!-- Post-Meeting AI Intelligence Synthesis Overlay -->
                <div class="report-overlay" id="report-state">
                    <div class="report-card">
                        <div class="report-header">
                            <i data-lucide="sparkles" style="color: var(--accent-blue)" size="36"></i>
                            <div class="report-title">
                                <h1>POST-MEETING AI ANALYSIS</h1>
                                <p style="color: var(--text-secondary); font-size: 0.7rem; margin-top: 4px; font-weight: 800; letter-spacing: 0.5px;">SYNTHESIZED COMPLIANT GTM DOSSIER</p>
                            </div>
                        </div>

                        <div class="dossier-grid">
                            <div class="dossier-item">
                                <div class="dossier-lbl">Prospect Name</div>
                                <div class="dossier-val" id="dossier-name">Bob</div>
                            </div>
                            <div class="dossier-item">
                                <div class="dossier-lbl">Intent Score</div>
                                <div class="dossier-val" style="color: var(--success);" id="dossier-intent">94% High</div>
                            </div>
                            <div class="dossier-item">
                                <div class="dossier-lbl">ICP Alignment</div>
                                <div class="dossier-val" style="color: var(--accent-blue);" id="dossier-icp">Grade A+</div>
                            </div>
                            <div class="dossier-item">
                                <div class="dossier-lbl">Pain Points Identified</div>
                                <div class="dossier-val" style="font-size: 0.8rem; line-height: 1.4;" id="dossier-pain">Manual RevOps overhead, CRM sync latency</div>
                            </div>
                        </div>

                        <div class="next-action-card">
                            <h4 style="font-size: 0.7rem; color: var(--accent-blue); margin-bottom: 4px; font-weight: 800; text-transform: uppercase;">Strategic Recommendation</h4>
                            <p style="font-size: 1rem; font-weight: 700; color: white;" id="dossier-recommendation">Send formal enterprise sales proposal and execute calendar integration plan.</p>
                        </div>

                        <button class="back-dashboard-btn" id="back-btn">RETURN TO GTM COMMAND CENTER</button>
                    </div>
                </div>
            </div>

            <!-- Right Side: AI Copilot Live Assist Panel -->
            <div class="copilot-panel">
                <div class="copilot-header">
                    <i data-lucide="bot" style="color: var(--accent-blue)"></i>
                    <h3>AI REVOPS COPILOT</h3>
                    <div style="margin-left: auto; display: flex; align-items: center; gap: 6px;">
                        <span style="font-size: 0.55rem; font-weight: 800; color: var(--text-secondary);">LISTENING</span>
                        <div class="pulse-light" style="background: var(--accent-blue); box-shadow: 0 0 8px var(--accent-blue);"></div>
                    </div>
                </div>

                <div class="copilot-body" id="transcription-viewport">
                    <div class="transcription-bubble" style="opacity: 1; transform: none;">
                        <div class="speaker-label">SYSTEM COGNITION</div>
                        AI Copilot successfully loaded. Awaiting video connection to synchronize real-time transcriptions...
                    </div>
                </div>

                <div class="progress-container">
                    <div class="progress-header">
                        <span>MEETING DURATION PROGRESS</span>
                        <span id="progress-val">0%</span>
                    </div>
                    <div class="bar-outer">
                        <div class="bar-inner" id="progress-bar"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        // 1. Dynamic Title from URL parameters
        const params = new URLSearchParams(window.location.search);
        let bookingId = params.get('id') || "1";
        let meetingTitle = params.get('title') || "Strategic Product Demo";
        document.getElementById('m-title').textContent = decodeURIComponent(meetingTitle);

        // Pre-parse the company/lead name from meetingTitle (e.g. "Strategic Demo: BobCorp" or similar)
        let companyName = "Enterprise Client";
        if (meetingTitle.includes(':')) {
            companyName = decodeURIComponent(meetingTitle.split(':')[1].trim());
        }

        // Map registered User identity if available
        let clientName = "Prospect Client";
        try {
            const userStr = localStorage.getItem('dca_user');
            if (userStr) {
                const user = JSON.parse(userStr);
                if (user.name) {
                    clientName = user.name;
                    document.getElementById('client-feed-name').textContent = `${clientName} (You)`;
                    document.getElementById('client-feed-label').textContent = clientName;
                }
            }
        } catch (e) {
            console.error("Error loading user credentials:", e);
        }

        const lobbyStatus = document.getElementById('lobby-status');
        const lobbyState = document.getElementById('lobby-state');
        const meetingState = document.getElementById('meeting-state');
        const reportState = document.getElementById('report-state');
        const joinBtn = document.getElementById('join-btn');
        const leaveBtn = document.getElementById('leave-btn');
        const backBtn = document.getElementById('back-btn');
        const transcriptionViewport = document.getElementById('transcription-viewport');
        const progressBar = document.getElementById('progress-bar');
        const progressVal = document.getElementById('progress-val');

        // Meeting simulated transcripts
        const transcripts = [
            { time: 1000, speaker: "Sarah Jenkins (Host)", text: "Hi! Welcome to the DCA Strategic Session. I saw your team has been facing massive scaling challenges. Could you tell me a bit more about your current flow?", isAi: false },
            { time: 3000, speaker: "AI Copilot Intel", text: "💡 PROSPECT ICP ANALYSIS: Prospect confirmed from enterprise domain. Company size qualified for premium RevOps automation roadmap.", isAi: true },
            { time: 4500, speaker: clientName, text: "Yes, exactly. We have 5,000 employees, and our sales team spends dozens of hours every week manually checking reps' calendars and rescheduling demos. It's causing a lot of drop-off.", isAi: false },
            { time: 6500, speaker: "AI Copilot Intel", text: "💡 PAIN POINT IDENTIFIED: Manual Scheduling Overhead. Time-loss estimated at 12 hours/rep/week. Intent rating elevated to 94% (Critical Need).", isAi: true },
            { time: 8000, speaker: "Sarah Jenkins (Host)", text: "That makes complete sense. With DCA, the AI agent dynamically qualifies leads, determines their ICP fit in real-time, and schedules meetings without human intervention. Does your budget support deploying this next quarter?", isAi: false },
            { time: 9500, speaker: clientName, text: "Absolutely, budget is fully confirmed. We need this solved immediately to stop leaking pipeline.", isAi: false },
            { time: 11000, speaker: "AI Copilot Intel", text: "💡 BANT QUALIFIED: Budget Confirmed. Authority Confirmed. Need is Critical. Timeline is Immediate (< 3 months). ICP classification: A+ VIP.", isAi: true }
        ];

        // Join secure session trigger
        joinBtn.onclick = () => {
            lobbyState.style.display = "none";
            meetingState.style.display = "flex";
            lobbyStatus.textContent = "SESSION IN PROGRESS";
            lobbyStatus.style.background = "rgba(99, 102, 241, 0.1)";
            lobbyStatus.style.color = "var(--accent-blue)";
            lobbyStatus.style.borderColor = "var(--accent-blue)";
            
            startSimulatedMeeting();
        };

        function startSimulatedMeeting() {
            // Clear system cognition bubble
            transcriptionViewport.innerHTML = "";

            let progress = 0;
            const duration = 12000; // 12 seconds simulated fast-forward
            const intervalTime = 100;
            const steps = duration / intervalTime;
            
            // Render transcripts over time
            transcripts.forEach(item => {
                setTimeout(() => {
                    renderBubble(item.speaker, item.text, item.isAi);
                }, item.time);
            });

            // Progress bar increment
            const interval = setInterval(() => {
                progress += (100 / steps);
                if (progress >= 100) {
                    progress = 100;
                    clearInterval(interval);
                    
                    // Meeting concluded -> transition to Post-Meeting report!
                    setTimeout(() => {
                        concludeMeeting();
                    }, 800);
                }
                progressBar.style.width = `${progress}%`;
                progressVal.textContent = `${Math.round(progress)}%`;
            }, intervalTime);
        }

        function renderBubble(speaker, text, isAi) {
            const bubble = document.createElement('div');
            bubble.className = `transcription-bubble ${isAi ? 'ai-intel' : ''}`;
            bubble.innerHTML = `
                <div class="speaker-label" style="color: ${isAi ? 'var(--accent-blue)' : 'var(--text-primary)'}">${speaker}</div>
                ${text}
            `;
            transcriptionViewport.appendChild(bubble);
            
            // Auto scroll transcription viewport
            setTimeout(() => {
                transcriptionViewport.scrollTo({
                    top: transcriptionViewport.scrollHeight,
                    behavior: 'smooth'
                });
            }, 50);
        }

        async function concludeMeeting() {
            lobbyStatus.textContent = "ANALYSIS COMPLETE";
            lobbyStatus.style.background = "rgba(16, 185, 129, 0.1)";
            lobbyStatus.style.color = "var(--success)";
            lobbyStatus.style.borderColor = "var(--success)";
            
            // Populate Dossier
            document.getElementById('dossier-name').textContent = companyName;
            document.getElementById('dossier-pain').textContent = "Manual GTM scheduling overhead, CRM latency, and pipeline leakage.";
            document.getElementById('dossier-recommendation').textContent = "Send formal Enterprise sales proposal and execute automated calendar integration rollout.";
            
            reportState.style.display = "flex";
            lucide.createIcons();

            // PING BACKEND to save Meeting Analysis Audit Log!
            try {
                const response = await fetch(`/api/v1/legacy-bookings/${bookingId}/analyze`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        prospect_name: companyName,
                        summary: "Strategic Alignment: Confirmed 5000 employee scale. High intent (94%) detected regarding scheduling latency.",
                        next_steps: "Deliver formal GTM deployment rollout schedule."
                    })
                });
                console.log("✅ Post-meeting AI analysis successfully logged to database:", await response.json());
            } catch (err) {
                console.error("❌ Failed to log post-meeting AI analysis:", err);
            }
        }

        leaveBtn.onclick = () => {
            concludeMeeting();
        };

        // Go back to Command Center dashboard
        backBtn.onclick = () => {
            window.location.href = "index.html";
        };
    </script>
</body>
</html>
